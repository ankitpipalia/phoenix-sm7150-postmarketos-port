+static struct mipi_dsi_driver g7b_37_02_0a_dsc_driver = {
+	.probe = g7b_37_02_0a_dsc_probe,
+	.remove = g7b_37_02_0a_dsc_remove,
+	.driver = {
+		.name = "panel-g7b-37-02-0a-dsc",

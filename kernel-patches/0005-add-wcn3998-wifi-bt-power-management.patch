diff --git a/arch/arm64/boot/dts/qcom/sm7150-xiaomi-common.dtsi b/arch/arm64/boot/dts/qcom/sm7150-xiaomi-common.dtsi
--- a/arch/arm64/boot/dts/qcom/sm7150-xiaomi-common.dtsi
+++ b/arch/arm64/boot/dts/qcom/sm7150-xiaomi-common.dtsi
@@ -35,6 +35,15 @@
 	battery: battery {
 		compatible = "simple-battery";
 
+		device-chemistry = "lithium-ion-polymer";
+
+		/*
+		 * Keep the maximum charging current conservative for now,
+		 * until we have thermal handling in the charging driver.
+		 * Downstream seems to have a upper limit of 3A.
+		 */
+		constant-charge-current-max-microamp = <1500000>;
+
 		voltage-min-design-microvolt = <3400000>;
 		voltage-max-design-microvolt = <4400000>;
 	};
@@ -742,28 +751,62 @@
 		bias-disable;
 	};
 
+	qup_uart3_default: qup-uart3-default-state {
+		cts-pins {
+			pins = "gpio38";
+			function = "qup03";
+			drive-strength = <2>;
+			bias-bus-hold;
+		};
+
+		rts-pins {
+			pins = "gpio39";
+			function = "qup03";
+			drive-strength = <2>;
+			bias-disable;
+		};
+
+		tx-pins {
+			pins = "gpio40";
+			function = "qup03";
+			drive-strength = <2>;
+			bias-disable;
+		};
+
+		rx-pins {
+			pins = "gpio41";
+			function = "qup03";
+			drive-strength = <2>;
+			bias-pull-up;
+		};
+	};
+
 	qup_uart3_sleep: qup-uart3-sleep-state {
 		cts-pins {
 			pins = "gpio38";
 			function = "gpio";
-			bias-pull-down;
+			drive-strength = <2>;
+			bias-bus-hold;
 		};
 
 		rts-pins {
 			pins = "gpio39";
 			function = "gpio";
+			drive-strength = <2>;
 			bias-pull-down;
 		};
 
 		tx-pins {
 			pins = "gpio40";
 			function = "gpio";
+			drive-strength = <2>;
 			bias-pull-up;
 		};
 
 		rx-pins {
 			pins = "gpio41";
 			function = "gpio";
+			drive-strength = <2>;
 			bias-pull-up;
 		};
 	};
@@ -828,12 +871,13 @@
 	interrupts-extended = <&intc GIC_SPI 604 IRQ_TYPE_LEVEL_HIGH>,
 			      <&tlmm 41 IRQ_TYPE_EDGE_FALLING>;
 
+	pinctrl-0 = <&qup_uart3_default>;
 	pinctrl-names = "default", "sleep";
 	pinctrl-1 = <&qup_uart3_sleep>;
 	status = "okay";
 
 	bluetooth: bluetooth {
-		compatible = "qcom,wcn3990-bt";
+		compatible = "qcom,wcn3998-bt";
 
 		vddio-supply = <&vreg_l10a_1p8>;
 		vddxo-supply = <&vreg_l1c_1p8>;
@@ -898,5 +942,6 @@
 	vdd-1.3-rfa-supply = <&vdd_wcss_adc_dac>;
 	vdd-3.3-ch0-supply = <&vreg_l10c_3p3>;
 	vdd-3.3-ch1-supply = <&vreg_l11c_3p3>;
+	qcom,snoc-host-cap-8bit-quirk;
 	status = "okay";
 };

diff --git a/arch/arm64/boot/dts/qcom/pm6150.dtsi b/arch/arm64/boot/dts/qcom/pm6150.dtsi
index 73a70610d..bc472f183 100644
--- a/arch/arm64/boot/dts/qcom/pm6150.dtsi
+++ b/arch/arm64/boot/dts/qcom/pm6150.dtsi
@@ -109,6 +109,18 @@ pm6150_typec: typec@1500 {
 			status = "disabled";
 		};
 
+		pm6150_charger: charger@1000 {
+			compatible = "qcom,pm6150-charger";
+			reg = <0x1000>;
+			interrupts = <0x0 0x13 0x4 IRQ_TYPE_EDGE_BOTH>,
+				     <0x0 0x12 0x2 IRQ_TYPE_EDGE_BOTH>,
+				     <0x0 0x16 0x1 IRQ_TYPE_EDGE_RISING>,
+				     <0x0 0x13 0x6 IRQ_TYPE_EDGE_RISING>;
+			interrupt-names = "usb-plugin", "bat-ov",
+					  "wdog-bark", "usbin-icl-change";
+			status = "disabled";
+		};
+
 		pm6150_temp: temp-alarm@2400 {
 			compatible = "qcom,spmi-temp-alarm";
 			reg = <0x2400>;
@@ -126,6 +138,18 @@ pm6150_adc: adc@3100 {
 			#size-cells = <0>;
 			#io-channel-cells = <1>;
 
+			channel@7 {
+				reg = <ADC5_USB_IN_I>;
+				label = "usb_in_i";
+				qcom,pre-scaling = <1 1>;
+			};
+
+			channel@8 {
+				reg = <ADC5_USB_IN_V_16>;
+				label = "usb_in_v";
+				qcom,pre-scaling = <1 16>;
+			};
+
 			channel@6 {
 				reg = <ADC5_DIE_TEMP>;
 				label = "die_temp";

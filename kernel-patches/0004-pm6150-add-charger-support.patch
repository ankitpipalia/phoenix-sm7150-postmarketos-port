+		      <&pm6150_adc ADC5_USB_IN_V_16>;
+	io-channel-names = "usbin_i", "usbin_v";
+	status = "okay";
+};
+
 &pm6150_qgauge {
 	monitored-battery = <&battery>;
 	status = "okay";
@@ -546,12 +554,17 @@ &pm6150_typec {
 	connector {
 		compatible = "usb-c-connector";
 

maintainer="Ankit Pipalia <REPLACE_WITH_YOUR_EMAIL>"
pkgname=firmware-xiaomi-phoenix
pkgver=1
pkgrel=0
pkgdesc="Firmware for Xiaomi POCO X2 / Redmi K30 4G (phoenix)"
url="https://github.com/Vanilla-s-Android-Stuff/firmware-xiaomi-phoenix"
arch="aarch64"
license="proprietary"
options="!check !strip !archcheck !tracedeps pmb:cross-native"

source="
	firmware-xiaomi-phoenix.tar.gz::https://local.pmbootstrap.example/firmware-xiaomi-phoenix.tar.gz
	30-initramfs-firmware-xiaomi-phoenix.files
"

package() {
	mkdir -p "$pkgdir"
	cp -a "$srcdir"/lib "$pkgdir"/

	install -Dm644 "$srcdir"/30-initramfs-firmware-xiaomi-phoenix.files \
		-t "$pkgdir"/usr/share/mkinitfs/files/
}


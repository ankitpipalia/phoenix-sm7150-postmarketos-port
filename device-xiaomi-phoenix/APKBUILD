# Reference: <https://postmarketos.org/devicepkg>
maintainer="Ankit Pipalia <ankit@example.com>"
pkgname=device-xiaomi-phoenix
pkgdesc="Xiaomi POCO X2 / Redmi K30 4G"
pkgver=1
pkgrel=8
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	alsa-ucm-conf-qcom-sm7150
	doas
	doas-sudo-shim
	firmware-qcom-sm7150
	firmware-xiaomi-phoenix
	hexagonrpcd
	linux-postmarketos-qcom-sm7150
	make-dynpart-mappings
	networkmanager
	bluez
	polkit-elogind
	postmarketos-base
	soc-qcom
	soc-qcom-qbootctl
	systemd-boot
	unl0kr-fbforcerefresh
"
makedepends="devicepkg-dev"
install="
	$pkgname.post-install
	$pkgname.post-upgrade
"
source="
	00-phoenix-notification-policy
	00-phoenix-notification-policy.lock
	90-phoenix-mac.conf
	90-phoenix-wlan-mac.preset
	dconf-profile-user
	phoenix-wlan-mac.service
	phoenix-wlan-mac.sh
	$pkgname.post-install
	$pkgname.post-upgrade
	doas-user-nopass.conf
	deviceinfo
	hexagonrpcd.confd
	modules-initfs
	sudoers-user-nopass.conf
"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname

	install -Dm644 "$srcdir"/hexagonrpcd.confd \
		"$pkgdir"/usr/share/hexagonrpcd/hexagonrpcd-sdsp.conf

	# Use hardware MAC addresses (disable NetworkManager randomized MAC mode).
	install -Dm644 "$srcdir"/90-phoenix-mac.conf \
		"$pkgdir"/etc/NetworkManager/conf.d/90-phoenix-mac.conf

	# Keep the display off for notification/task-complete events.
	install -Dm644 "$srcdir"/00-phoenix-notification-policy \
		"$pkgdir"/etc/dconf/db/local.d/00-phoenix-notification-policy
	install -Dm644 "$srcdir"/00-phoenix-notification-policy.lock \
		"$pkgdir"/etc/dconf/db/local.d/locks/00-phoenix-notification-policy
	install -Dm644 "$srcdir"/dconf-profile-user \
		"$pkgdir"/etc/dconf/profile/user

	# Ath10k can fall back to random MAC when calibration data doesn't provide
	# one. Apply a deterministic, persisted MAC before NetworkManager starts.
	install -Dm755 "$srcdir"/phoenix-wlan-mac.sh \
		"$pkgdir"/usr/libexec/phoenix-wlan-mac.sh
	install -Dm644 "$srcdir"/phoenix-wlan-mac.service \
		"$pkgdir"/usr/lib/systemd/system/phoenix-wlan-mac.service
	install -Dm644 "$srcdir"/90-phoenix-wlan-mac.preset \
		"$pkgdir"/usr/lib/systemd/system-preset/90-phoenix-wlan-mac.preset
	mkdir -p "$pkgdir"/etc/systemd/system/multi-user.target.wants
	ln -sf /usr/lib/systemd/system/phoenix-wlan-mac.service \
		"$pkgdir"/etc/systemd/system/multi-user.target.wants/phoenix-wlan-mac.service

	# Passwordless root access for default postmarketOS user over doas/sudo.
	# This mirrors the live fix and makes it persistent across fresh flashes.
	install -Dm600 "$srcdir"/doas-user-nopass.conf \
		"$pkgdir"/etc/doas.d/99-user-nopass.conf
	install -Dm440 "$srcdir"/sudoers-user-nopass.conf \
		"$pkgdir"/etc/sudoers.d/90-user-nopass

	# Enable NetworkManager at boot (required for WiFi/Ethernet in phosh)
	mkdir -p "$pkgdir"/etc/runlevels/default
	ln -sf /etc/init.d/networkmanager \
		"$pkgdir"/etc/runlevels/default/networkmanager

	# Enable Bluetooth at boot
	ln -sf /etc/init.d/bluetooth \
		"$pkgdir"/etc/runlevels/default/bluetooth

	# Enable elogind at boot (required for phosh reboot/shutdown)
	ln -sf /etc/init.d/elogind \
		"$pkgdir"/etc/runlevels/default/elogind
}

subpackages="$pkgname-nonfree-firmware:nonfree_firmware"

nonfree_firmware() {
	pkgdesc="Firmware for GPU, WiFi, modem, DSP (required for most functionality)"
	depends="firmware-xiaomi-phoenix"
	mkdir "$subpkgdir"
}


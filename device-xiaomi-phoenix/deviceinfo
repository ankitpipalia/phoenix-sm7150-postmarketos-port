# Reference: <https://postmarketos.org/deviceinfo>
# Please use double quotes only. You can source this file in shell scripts.

deviceinfo_format_version="0"
deviceinfo_name="Xiaomi POCO X2 / Redmi K30 4G"
deviceinfo_manufacturer="Xiaomi"
deviceinfo_codename="xiaomi-phoenix"
deviceinfo_year="2019"
deviceinfo_dtb="qcom/sm7150-xiaomi-phoenix"
deviceinfo_arch="aarch64"
deviceinfo_flash_kernel_on_update="true"

# Device related
deviceinfo_drm="true"
deviceinfo_chassis="handset"
deviceinfo_external_storage="true"
deviceinfo_screen_width="1080"
deviceinfo_screen_height="2400"

# Bootloader related - U-Boot on boot partition provides UEFI
# U-Boot reads FAT32 ESP from combined image on userdata
deviceinfo_flash_method="fastboot"
deviceinfo_boot_filesystem="fat32"

# UFS storage
deviceinfo_rootfs_image_sector_size="4096"

# Super/dynamic partition
deviceinfo_super_partitions="/dev/disk/by-partlabel/super"
